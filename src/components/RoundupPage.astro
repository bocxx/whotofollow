---
/**
 * RoundupPage — gedeeld template voor de evergreen "wie volgen"-overzichten.
 * Eén platform of de curator-picks, gesorteerd op volgers + live aggregaat-
 * cijfers in de intro (auto-ververst → elke crawl unieke, actuele content).
 */
import Layout from '../layouts/Layout.astro';
import CreatorCard from './molecules/CreatorCard.astro';
import LoadMore from './LoadMore.astro';
import { siteConfig } from '../config/site';
import { getRoundupConfig, getRoundupData, ROUNDUPS } from '../lib/roundups';
import { getGeneratedAt, formatNumber } from '../lib/data';
import { useTranslations, localizedHref, getDateLocale, type Locale } from '../i18n/messages';
import { Star, Github, Youtube, Twitter, AtSign, ArrowLeft, ArrowRight } from '@lucide/astro';

interface Props { slug: string; locale: Locale; }
const { slug, locale } = Astro.props;

const cfg = getRoundupConfig(slug)!;
const copy = cfg[locale];
const data = getRoundupData(cfg);
const t = useTranslations(locale);

const ICONS = { star: Star, github: Github, youtube: Youtube, twitter: Twitter, bluesky: AtSign } as const;
const Icon = ICONS[cfg.icon];

const updated = new Date(getGeneratedAt()).toLocaleDateString(getDateLocale(locale), {
  day: 'numeric', month: 'short',
});

// Live, data-gedreven contextzin — maakt elke pagina uniek + actueel.
const topFollowers = data.top ? formatNumber((data.top.stats as any)?.followers ?? 0) : '';
let context = '';
if (data.top) {
  context = locale === 'nl'
    ? `We tonen er ${data.total}. De grootste is ${data.top.name} met ${topFollowers} volgers.`
    : `Showing ${data.total}. The largest is ${data.top.name} with ${topFollowers} followers.`;
}

const pageUrl = `${siteConfig.url}${localizedHref(`/${slug}`, locale)}`;
const others = ROUNDUPS.filter((r) => r.slug !== slug);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: copy.title,
  description: copy.lead,
  url: pageUrl,
  inLanguage: locale,
  isPartOf: { '@type': 'WebSite', name: t.siteName, url: siteConfig.url },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: data.items.length,
    itemListElement: data.items.slice(0, 20).map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${siteConfig.url}${localizedHref(`/${c.slug}`, locale)}`,
      name: c.name,
    })),
  },
};
---

<Layout title={`${copy.title} · ${t.siteName}`} description={copy.lead} ogType="website">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <main class="container container-wide">
    <a href={localizedHref('/', locale)} class="roundup__back">
      <ArrowLeft size={14} stroke-width={2} /> {locale === 'nl' ? 'Naar alle creators' : 'Back to all creators'}
    </a>

    <header class="roundup-hero">
      <div class="roundup-hero__icon"><Icon size={26} stroke-width={1.6} /></div>
      <span class="roundup-hero__kicker">{copy.kicker}</span>
      <h1 class="roundup-hero__title">{copy.title}</h1>
      <p class="roundup-hero__lead">{copy.lead}</p>
      {context && <p class="roundup-hero__context">{context}</p>}
      <p class="roundup-hero__meta">
        <strong>{formatNumber(data.total)}</strong> creators
        · {locale === 'nl' ? 'bijgewerkt' : 'updated'} {updated}
      </p>
    </header>

    <div class="feed-grid" id="roundup-grid">
      {data.items.map((c) => <CreatorCard creator={c} locale={locale} />)}
    </div>

    <LoadMore gridId="roundup-grid" initial={24} step={24} locale={locale} />

    <section class="roundup-more">
      <h2>{locale === 'nl' ? 'Meer overzichten' : 'More roundups'}</h2>
      <div class="roundup-more__links">
        {others.map((r) => (
          <a href={localizedHref(`/${r.slug}`, locale)} class="roundup-more__link">
            <span>{r[locale].title}</span>
            <ArrowRight size={14} stroke-width={2} />
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .roundup__back {
    display: inline-flex; align-items: center; gap: var(--space-1);
    color: var(--text-muted); font-size: var(--text-sm);
    text-decoration: none; margin: var(--space-4) 0 var(--space-2);
    transition: color var(--duration-fast);
  }
  .roundup__back:hover { color: var(--primary-bright); }

  .roundup-hero {
    max-width: 760px; margin: 0 auto var(--space-8);
    padding-top: var(--space-4); text-align: center;
  }
  .roundup-hero__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 52px; height: 52px; border-radius: var(--radius-lg);
    background: color-mix(in oklch, var(--primary-bright) 12%, transparent);
    color: var(--primary-bright); margin-bottom: var(--space-3);
  }
  .roundup-hero__kicker {
    display: block; text-transform: uppercase; letter-spacing: var(--tracking-wider);
    font-size: var(--text-xs); font-weight: var(--font-semibold);
    color: var(--text-muted); margin-bottom: var(--space-2);
  }
  .roundup-hero__title {
    font-family: var(--font-display); font-size: var(--text-4xl);
    font-weight: var(--font-bold); line-height: 1.1;
    letter-spacing: var(--tracking-tight); margin: 0 0 var(--space-4);
  }
  .roundup-hero__lead {
    color: var(--text-secondary); font-size: var(--text-lg);
    line-height: var(--leading-relaxed); margin: 0 auto var(--space-3); max-width: 680px;
  }
  .roundup-hero__context {
    color: var(--text-secondary); font-size: var(--text-base);
    margin: 0 auto var(--space-4); max-width: 680px;
  }
  .roundup-hero__context strong, .roundup-hero__meta strong { color: var(--text-primary); }
  .roundup-hero__meta {
    font-family: var(--font-mono); font-size: var(--text-sm);
    color: var(--text-muted); margin: 0;
  }

  .roundup-more {
    margin-top: var(--space-16); padding-top: var(--space-8);
    border-top: 1px solid var(--border-subtle);
  }
  .roundup-more h2 {
    font-size: var(--text-xl); font-weight: var(--font-bold); margin: 0 0 var(--space-4);
  }
  .roundup-more__links {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: var(--space-3);
  }
  .roundup-more__link {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-3);
    padding: var(--space-4); border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg); background: var(--bg-panel);
    color: var(--text-primary); text-decoration: none;
    font-weight: var(--font-medium); font-size: var(--text-sm);
    transition: border-color var(--duration-fast), transform var(--duration-fast);
  }
  .roundup-more__link:hover { border-color: var(--border-accent); transform: translateY(-2px); }
  .roundup-more__link svg { color: var(--primary-bright); flex-shrink: 0; }
</style>
