---
import { Users, Languages } from '@lucide/astro';
import { useTranslations, localizedHref, getAlternateUrl, type Locale } from '../i18n/messages';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const otherLocale: Locale = locale === 'nl' ? 'en' : 'nl';
const otherHref = getAlternateUrl(Astro.url.pathname, locale);

const nav = [
  { label: t.nav.everyone, href: localizedHref('/', locale) },
  { label: t.nav.github, href: localizedHref('/?platform=github', locale) },
  { label: t.nav.youtube, href: localizedHref('/?platform=youtube', locale) },
  { label: t.nav.twitter, href: localizedHref('/?platform=twitter', locale) },
  { label: t.nav.bluesky, href: localizedHref('/?platform=bluesky', locale) },
  { label: t.nav.network, href: localizedHref('/network', locale) },
  { label: t.nav.galaxy, href: localizedHref('/galaxy', locale) },
  { label: t.nav.about, href: t.aboutPath },
];
---

<header class="site-header">
  <div class="container container-wide site-header__inner">
    <a href={localizedHref('/', locale)} class="site-logo" aria-label="whotofollow home">
      <Users size={18} stroke-width={2.2} style="color: var(--primary-bright); vertical-align: -3px;" />
      who<span class="accent">tofollow</span>
    </a>
    <nav class="site-nav" aria-label={locale === 'nl' ? 'Hoofdnavigatie' : 'Primary'}>
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href={otherHref} class="lang-toggle" aria-label={locale === 'nl' ? 'Switch to English' : 'Schakel naar Nederlands'}>
        <Languages size={14} stroke-width={2} style="vertical-align: -2px; margin-right: 4px;" />
        {otherLocale.toUpperCase()}
      </a>
    </nav>
  </div>
</header>

<style>
  .lang-toggle {
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary) !important;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
  }
  .lang-toggle:hover {
    color: var(--primary-bright) !important;
    border-color: var(--border-accent);
  }
</style>
