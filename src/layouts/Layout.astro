---
/**
 * whotofollow.online — Base Layout
 *
 * Built on astro-starter pattern (same as hln-v2 quality level).
 * Additions over the generic starter:
 *  - hreflang (NL/EN bilingual site)
 *  - Locale-aware canonical + meta
 *  - Umami analytics (inline, View-Transitions-aware)
 */
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/main.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import IconSprite from '../components/atoms/IconSprite.astro';
import BackToTop from '../components/BackToTop.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import { siteConfig } from '../config/site';
import { useTranslations, getAlternateUrl, type Locale } from '../i18n/messages';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  /** Relative path to LCP hero image — adds <link rel=preload fetchpriority=high> */
  preloadImage?: string;
  /** noindex this page (e.g. stale archive pages) */
  noindex?: boolean;
  /** CSS selector for reading progress bar (article pages only) */
  progressTarget?: string;
}

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);

const {
  title,
  description = t.siteDescription,
  ogImage,
  ogType = 'website',
  preloadImage,
  noindex = false,
  progressTarget = '.article__content',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, siteConfig.url);
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteConfig.url}${ogImage}`)
  : `${siteConfig.url}${siteConfig.defaultOg}`;
const ogImageType = /\.png$/i.test(resolvedOgImage) ? 'image/png'
  : /\.jpe?g$/i.test(resolvedOgImage) ? 'image/jpeg' : 'image/webp';

// hreflang — same logical page in each locale
const currentPath = Astro.url.pathname;
const altPath = getAlternateUrl(currentPath, locale);
const nlPath = locale === 'nl' ? currentPath : altPath;
const enPath = locale === 'en' ? currentPath : altPath;
const hreflangs = [
  { hreflang: 'nl', href: `${siteConfig.url}${nlPath}` },
  { hreflang: 'en', href: `${siteConfig.url}${enPath}` },
  { hreflang: 'x-default', href: `${siteConfig.url}${nlPath}` },
];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <!-- Dual theme-color: browser chrome matches the active theme -->
    <meta name="theme-color" content="#010405" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#faf9f7" media="(prefers-color-scheme: light)" />
    <meta name="generator" content={Astro.generator} />

    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalURL.href} />

    <!-- hreflang — bilingual NL/EN -->
    {hreflangs.map((h) => <link rel="alternate" hreflang={h.hreflang} href={h.href} />)}

    <!-- Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:site_name"   content={t.siteName} />
    <meta property="og:locale"      content={locale === 'en' ? 'en_US' : 'nl_NL'} />
    <meta property="og:url"         content={canonicalURL.href} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={resolvedOgImage} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type"   content={ogImageType} />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={resolvedOgImage} />

    <!-- Preload LCP image — critical CWV improvement on hero pages -->
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={`${t.siteName} — feed`}
      href={locale === 'en' ? '/en/rss.xml' : '/rss.xml'} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Brand fonts (Astro Fonts API). Boldonse + Geist preloaded voor LCP. -->
    <Font cssVariable="--font-boldonse" preload />
    <Font cssVariable="--font-geist" preload />
    <Font cssVariable="--font-jetbrains-mono" />

    <title>{title}</title>

    <!-- ⚡ FOUC-prevention — MUST be inline, runs before first paint -->
    <script is:inline>
      (function () {
        var s = localStorage.getItem('theme');
        var t = s || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', t);
      })();
      // Re-apply after each View Transition (Astro swaps the <html> element)
      document.addEventListener('astro:after-swap', function () {
        var t = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', t);
      });
    </script>

    <!-- Umami Analytics — View Transitions-aware -->
    <link rel="preconnect" href="https://cloud.umami.is" crossorigin />
    <link rel="dns-prefetch" href="https://cloud.umami.is" />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="a043c801-eb28-429f-8f6e-28594996909c" data-auto-track="false"></script>
    <script is:inline>{`
      (function(){
        function t(){if(window.umami&&typeof window.umami.track==='function')window.umami.track();}
        if(document.readyState!=='loading')t();else document.addEventListener('DOMContentLoaded',t);
        document.addEventListener('astro:page-load',t);
      })();
    `}</script>
    <script is:inline>
      // Umami custom events (netwerk-breed, juni 2026): ai-referral (AEO),
      // cross-domain-click, source-link-click, tab-switch, audio-play, read-depth.
      // Rauwe JS (geen template-wrapper). window.umami komt van het externe script.
      (function () {
        var CONTENT_SEL = '.article__content, .prose, .content-col';
        var NET = { 'hetlaatsteainieuws.nl':1,'debesteaitools.nl':1,'aiplatformmkb.nl':1,'ainieuwsradar.nl':1,'feedzz.online':1,'whotofollow.online':1 };
        function norm(h){return (h||'').toLowerCase().replace(/^www\./,'');}
        function slugOf(){var p=location.pathname.replace(/\/+$/,'');return p.split('/').filter(Boolean).pop()||'';}
        function track(name,data){try{if(window.umami&&window.umami.track)window.umami.track(name,data);}catch(e){}}
        function trackReady(name,data){function go(){if(window.umami&&window.umami.track){window.umami.track(name,data);return true;}return false;}if(go())return;var n=0;var iv=setInterval(function(){if(go()||++n>100)clearInterval(iv);},50);}
        var ENGINES={'chatgpt.com':'chatgpt','chat.openai.com':'chatgpt','openai.com':'chatgpt','perplexity.ai':'perplexity','gemini.google.com':'gemini','copilot.microsoft.com':'copilot','m365.cloud.microsoft':'copilot','claude.ai':'claude','you.com':'you','phind.com':'phind','grok.com':'grok','x.ai':'grok','mistral.ai':'mistral','chat.mistral.ai':'mistral','poe.com':'poe','deepseek.com':'deepseek','chat.deepseek.com':'deepseek','meta.ai':'meta'};
        function engineFromValue(v){if(!v)return null;v=v.toLowerCase();if(ENGINES[norm(v)])return ENGINES[norm(v)];var keys=['chatgpt','openai','perplexity','gemini','copilot','claude','phind','grok','mistral','deepseek','meta.ai'];for(var i=0;i<keys.length;i++){if(v.indexOf(keys[i])!==-1)return keys[i]==='meta.ai'?'meta':keys[i].replace('openai','chatgpt');}return null;}
        (function(){var src=null;try{var p=new URLSearchParams(location.search);src=p.get('utm_source')||p.get('ref')||p.get('source');}catch(e){}var eng=engineFromValue(src),via='param';if(!eng){var ref=document.referrer||'';if(ref){try{var host=norm(new URL(ref).hostname);if(host&&host!==norm(location.hostname)&&ENGINES[host]){eng=ENGINES[host];via='referrer';}}catch(e){}}}if(eng)trackReady('ai-referral',{engine:eng,via:via,landing:location.pathname+location.search});})();
        document.addEventListener('click',function(e){var t=e.target;if(!t||!t.closest)return;var tab=t.closest('[data-tab], [data-tab-top]');if(tab){var which=tab.getAttribute('data-tab')||tab.getAttribute('data-tab-top');if(which)track('tab-switch',{tab:which,page:location.pathname});}var a=t.closest('a[href]');if(!a)return;var href=a.getAttribute('href')||'';if(!/^https?:\/\//i.test(href))return;var h;try{h=norm(new URL(href).hostname);}catch(_){return;}if(!h||h===norm(location.hostname))return;if(NET[h])track('cross-domain-click',{to:h,href:href,from:location.pathname});else if(a.closest(CONTENT_SEL))track('source-link-click',{host:h,href:href,from:location.pathname});},true);
        document.addEventListener('play',function(e){if(e.target&&e.target.tagName==='AUDIO')track('audio-play',{slug:slugOf()});},true);
        var fired={};function checkDepth(){var el=document.querySelector(CONTENT_SEL);if(!el)return;var total=el.offsetHeight;if(total<=0)return;var rect=el.getBoundingClientRect();var pct=Math.min(total,Math.max(0,window.innerHeight-rect.top))/total;var marks=[25,50,75,100];for(var i=0;i<marks.length;i++){var m=marks[i];if(pct>=m/100&&!fired[m]){fired[m]=1;track('read-depth',{pct:m,slug:slugOf()});}}}
        var ticking=false;window.addEventListener('scroll',function(){if(ticking)return;ticking=true;requestAnimationFrame(function(){checkDepth();ticking=false;});},{passive:true});
        function resetForPage(){fired={};checkDepth();}
        if(document.readyState!=='loading')resetForPage();else document.addEventListener('DOMContentLoaded',resetForPage);
        document.addEventListener('astro:page-load',resetForPage);
      })();
    </script>

    <slot name="head" />

    <!-- View Transitions — SPA-feel without full-page reload -->
    <ClientRouter />
  </head>
  <body>
    {/* Lucide <symbol>-sprite — één definitie per pagina; creator-cards
        verwijzen ernaar via <use> (SpriteIcon.astro). */}
    <IconSprite />
    <ReadingProgress selector={progressTarget} />
    <SiteHeader locale={locale} />

    <main id="main">
      <slot />
    </main>

    <SiteFooter locale={locale} />
    <BackToTop />
  </body>
</html>
