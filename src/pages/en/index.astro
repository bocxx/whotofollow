---
import Layout from '../../layouts/Layout.astro';
import CreatorCard from '../../components/molecules/CreatorCard.astro';
import { siteConfig } from '../../config/site';
import { getAllCreators, getCounts, getGeneratedAt, platformLabels, categoryLabel } from '../../lib/data';
import { useTranslations, getDateLocale, type Locale } from '../../i18n/messages';
import {
  Users, Network, Sparkles, Code, Bot, BookOpen, Briefcase,
  Microscope, Palette, GraduationCap, Wrench, ShieldCheck, Megaphone, Layers, ChevronDown,
} from '@lucide/astro';

const CategoryIcon: Record<string, any> = {
  'claude': Sparkles, 'coding': Code, 'agents': Bot,
  'beginners': BookOpen, 'business': Briefcase, 'research': Microscope,
  'creative': Palette, 'fundamentals': GraduationCap,
  'tool-insights': Wrench, 'official': ShieldCheck, 'branding': Megaphone,
};

// Stable display order (most relevant categories first, niche at end)
const CATEGORY_ORDER = [
  'claude', 'coding', 'agents', 'tool-insights', 'fundamentals',
  'research', 'business', 'creative', 'beginners', 'branding', 'official',
];

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);

const creators = getAllCreators();
const counts = getCounts();
const generatedAt = getGeneratedAt();

const updated = new Date(generatedAt).toLocaleDateString(getDateLocale(locale), {
  day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit',
});

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: t.siteName,
  url: siteConfig.url,
  description: t.siteDescription,
  inLanguage: locale,
};
---

<Layout title={`${t.siteName} — ${counts.total}+ ${locale === 'nl' ? 'AI makers, onderzoekers en bedrijven' : 'AI makers, researchers and companies'}`}
        description={t.siteDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
  </Fragment>

  <main class="container container-wide">
    <section class="hero">
      <div class="hero__meta">
        <span class="badge badge--primary"><Users size={11} stroke-width={2} /> {t.hero.graph}</span>
        <span>{t.hero.updated} {updated}</span>
      </div>
      <h1 class="hero__title">
        <span class="hero__gradient">{t.hero.titleA}</span>
        <br />{t.hero.titleB}
      </h1>
      <p class="hero__sub">{t.hero.sub(counts.total, counts.cross)}</p>
    </section>

    <div class="filter-bar" data-dim="scope">
      <button class="filter-pill is-active" data-filter="all">{t.filters.everyone} · {counts.total}</button>
      <button class="filter-pill filter-pill--picks" data-filter="picks">
        <Sparkles size={11} stroke-width={2} style="vertical-align: -2px; margin-right: 3px;" />
        {t.filters.picks} · {counts.picks ?? 0}
      </button>
      <button class="filter-pill" data-filter="cross">
        <Network size={11} stroke-width={2} style="vertical-align: -2px; margin-right: 3px;" />
        {t.filters.cross} · {counts.cross}
      </button>
      {Object.entries(counts.byPlatform).map(([p, n]) => (
        <button class="filter-pill" data-filter={p}>{platformLabels[p] ?? p} · {n}</button>
      ))}
    </div>

    <div class="cat-bar" data-dim="category" aria-label={t.filters.categoryHeading}>
      <button class="cat-pill is-active" data-cat-filter="all" type="button">
        <Layers size={11} stroke-width={2} />
        {t.filters.categoryAll}
      </button>
      {CATEGORY_ORDER
        .filter((c) => (counts.byCategory?.[c] ?? 0) > 0)
        .map((c) => {
          const Icon = CategoryIcon[c];
          const n = counts.byCategory[c];
          return (
            <button class="cat-pill" data-cat={c} data-cat-filter={c} type="button">
              {Icon && <Icon size={11} stroke-width={1.8} />}
              <span>{categoryLabel(c, locale)}</span>
              <span class="cat-pill__count">{n}</span>
            </button>
          );
        })}
    </div>

    <div class="feed-grid" id="feed-grid">
      {creators.map((c) => <CreatorCard creator={c} locale={locale} />)}
    </div>

    <p class="empty" id="feed-empty" hidden>{t.ui.noResults}</p>

    <div class="load-more" id="home-load-more" data-count-tmpl={t.ui.showingTemplate} hidden>
      <button type="button" class="btn btn-outline btn-lg" id="home-load-more-btn">
        <span>{t.ui.loadMore}</span>
        <ChevronDown size={18} stroke-width={2} />
      </button>
      <p class="load-more__count" id="home-load-more-count" aria-live="polite"></p>
    </div>
  </main>
</Layout>

<script>
  // Two-dimensional filtering (scope × category) + progressive reveal.
  // A card shows only when BOTH dimensions match AND it's within the current
  // reveal budget. "Show more" lifts the budget; changing a filter resets it.
  const grid = document.getElementById('feed-grid');
  const scopePills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const catPills = document.querySelectorAll<HTMLButtonElement>('.cat-pill');
  const emptyEl = document.getElementById('feed-empty');
  const moreWrap = document.getElementById('home-load-more');
  const moreBtn = document.getElementById('home-load-more-btn');
  const moreCount = document.getElementById('home-load-more-count');
  const countTmpl = moreWrap?.dataset.countTmpl ?? '';

  const STEP = 24;
  const cards = grid
    ? Array.from(grid.querySelectorAll<HTMLAnchorElement>('.creator-card, .feed-card'))
    : [];

  let activeScope = 'all';
  let activeCategory = 'all';
  let limit = STEP;

  function matches(c: HTMLElement): boolean {
    const src = c.dataset.source;
    const isCross = !!(c.querySelector('.multi-platform-pill') || c.querySelector('.badge--secondary'));
    const isPick = c.dataset.pick === '1';
    const cats = (c.dataset.cats ?? '').split(' ').filter(Boolean);

    let scopeMatch = true;
    if (activeScope === 'cross') scopeMatch = isCross;
    else if (activeScope === 'picks') scopeMatch = isPick;
    else if (activeScope !== 'all') scopeMatch = src === activeScope;

    const catMatch = activeCategory === 'all' || cats.includes(activeCategory);
    return scopeMatch && catMatch;
  }

  function apply() {
    let total = 0;
    let shown = 0;
    cards.forEach((c) => {
      if (matches(c)) {
        total++;
        if (shown < limit) { c.style.display = ''; shown++; }
        else c.style.display = 'none';
      } else {
        c.style.display = 'none';
      }
    });
    if (emptyEl) emptyEl.hidden = total !== 0;
    if (moreWrap) {
      moreWrap.hidden = shown >= total;
      if (moreCount && countTmpl) {
        moreCount.textContent = countTmpl
          .replace('{shown}', String(shown))
          .replace('{total}', String(total));
      }
    }
  }

  function resetAndApply() { limit = STEP; apply(); }

  scopePills.forEach((p) => {
    p.addEventListener('click', () => {
      scopePills.forEach((x) => x.classList.remove('is-active'));
      p.classList.add('is-active');
      activeScope = p.dataset.filter || 'all';
      resetAndApply();
    });
  });

  catPills.forEach((p) => {
    p.addEventListener('click', () => {
      catPills.forEach((x) => x.classList.remove('is-active'));
      p.classList.add('is-active');
      activeCategory = p.dataset.catFilter || 'all';
      resetAndApply();
    });
  });

  moreBtn?.addEventListener('click', () => { limit += STEP; apply(); });

  // URL params: ?platform=/?filter= (scope), ?cat=/?category= (category)
  const params = new URLSearchParams(location.search);
  const scopeParam = params.get('platform') || params.get('filter');
  if (scopeParam) {
    document.querySelector<HTMLButtonElement>(`.filter-pill[data-filter="${scopeParam}"]`)?.click();
  }
  const catParam = params.get('cat') || params.get('category');
  if (catParam) {
    document.querySelector<HTMLButtonElement>(`.cat-pill[data-cat-filter="${catParam}"]`)?.click();
  }

  // Initial paint (covers the no-URL-param case)
  apply();
</script>
