---
import Layout from '../../layouts/Layout.astro';
import CreatorCard from '../../components/molecules/CreatorCard.astro';
import { getAllCreators } from '../../lib/data';
import { siteConfig } from '../../config/site';
import type { Locale } from '../../i18n/messages';

const locale: Locale = 'en';

const FEATURED_LABS = ['anthropicai', 'openai', 'google-deepmind', 'facebook', 'mistralai', 'huggingface', 'microsoft'];
const FEATURED_NL = ['allai', 'rathenau-instituut'];

const all = getAllCreators();
const bySlug = (slug: string) => all.find((c) => c.slug === slug);

const labs = FEATURED_LABS.map(bySlug).filter(Boolean) as Awaited<ReturnType<typeof getAllCreators>>;
const nl = FEATURED_NL.map(bySlug).filter(Boolean) as Awaited<ReturnType<typeof getAllCreators>>;

const title = 'AI organisations — whotofollow';
const description = 'The labs, institutes and organisations shaping the direction of AI — from OpenAI and Anthropic to the Rathenau Instituut.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `${siteConfig.url}/en/organisations`,
  inLanguage: 'en',
  isPartOf: { '@type': 'WebSite', name: 'whotofollow', url: siteConfig.url },
};
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <div class="container">
    <header class="page-head">
      <h1 class="page-head__title">AI organisations</h1>
      <p class="page-head__lead">The labs, institutes and organisations shaping the direction of AI.</p>
    </header>

    <section class="org-section">
      <h2 class="org-section__heading">International labs</h2>
      <div class="creator-grid">
        {labs.map((c) => <CreatorCard creator={c} locale={locale} />)}
      </div>
    </section>

    <section class="org-section">
      <h2 class="org-section__heading">Netherlands &amp; Europe</h2>
      <div class="creator-grid">
        {nl.map((c) => <CreatorCard creator={c} locale={locale} />)}
      </div>
    </section>
  </div>
</Layout>

<style>
  .page-head {
    padding: var(--space-12) 0 var(--space-8);
  }
  .page-head__title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    margin: 0 0 var(--space-3);
  }
  .page-head__lead {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0;
  }

  .org-section {
    margin-bottom: var(--space-12);
  }
  .org-section__heading {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--text-muted);
    margin: 0 0 var(--space-5);
  }

  .creator-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
  }
</style>
